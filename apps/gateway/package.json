{
  "name": "@match-dna/gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts src/start.ts --format esm --dts --sourcemap --clean",
    "dev": "tsx watch src/start.ts",
    "start": "node dist/start.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --pool=forks --maxWorkers=1",
    "test:coverage": "vitest run --coverage --pool=forks --maxWorkers=1",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@match-dna/fixtures": "workspace:*",
    "@match-dna/sdk": "workspace:*",
    "@match-dna/txline": "workspace:*",
    "fastify": "^5.6.1"
  }
}
