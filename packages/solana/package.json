{
  "name": "@match-dna/solana",
  "version": "0.1.0",
  "description": "Witness/genome PDA, commitment, and proof-gated sealing helpers.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./idl": "./idl/match_dna.json"
  },
  "files": [
    "dist",
    "idl",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap --clean",
    "dev": "tsup src/index.ts --format esm --dts --sourcemap --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --pool=forks --maxWorkers=1",
    "test:coverage": "vitest run --coverage --pool=forks --maxWorkers=1",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@match-dna/core": "workspace:*",
    "@match-dna/txline": "workspace:*",
    "@solana/web3.js": "^1.98.4"
  },
  "devDependencies": {
    "@match-dna/fixtures": "workspace:*"
  }
}
