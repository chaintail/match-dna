{
  "name": "match-dna",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test --concurrency=1",
    "test:coverage": "turbo run test:coverage --concurrency=1",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "demo:generate": "pnpm --filter @match-dna/cli generate",
    "demo:verify": "pnpm --filter @match-dna/cli verify-demo",
    "clean": "turbo run clean && rm -rf .turbo coverage"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/node": "^24.13.3",
    "@vitest/coverage-v8": "^3.2.7",
    "fast-check": "^4.9.0",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "turbo": "^2.10.5",
    "typescript": "^5.9.3",
    "vitest": "^3.2.7"
  }
}
